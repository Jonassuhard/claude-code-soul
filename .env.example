# claude-code-soul — .env.example
# Copy to .env, fill in, then run ./setup.sh
# Variables map 1:1 to {{XXX}} placeholders in skills/agents/hooks/rules.

# ===== Identity (required) =====
USER_NAME=Marie                      # Your first name or alias. Replaces {{USER_NAME}}.
USER_AGE=29                          # Optional, used in soul.md context
USER_LOCATION="Lyon, France"         # City, country
USER_PRIMARY_HATS="UX design, frontend dev, design systems"   # 2-7 expertise hats

# ===== Workspace paths =====
WORKSPACE=workspace                  # Top-level workspace folder name (under ~/Desktop/)
EXT_DRIVE=/Volumes/Backup            # External drive for archives (used by some hooks)

# ===== Active projects (leave empty if N/A) =====
GAME_PROJECT=                        # Gamedev project name (e.g. "FightSim", "PixelArena")
YT_CHANNEL=                          # YouTube handle (e.g. "@yourchannel")
PROJECT_APP=                         # Side app project name
PROJECT_EDU_APP=                     # Pedagogical/edu app

# ===== Clients (use generic placeholders for NDA work) =====
CLIENT_EDU=ClientA                   # Education client
CLIENT_WP=ClientB                    # WordPress/CMS client
CLIENT_WP_DIR=CLIENTB                # Uppercase folder version
CLIENT_LOCAL=ClientC                 # Local business client
CLIENT_CONTACT=                      # Main contact (empty if none)
CLIENT_LOCAL_CONTACT=
CLIENT_LOCAL_HANDLE=
CITY=                                # City of local client

# ===== School / pedagogy =====
TUTOR=                               # Academic supervisor name (if student)
EMPLOYEE_ID=                         # If apprentice/employee ID needed for HR templates

# ===== Family / personal (for soul.md context only — keep empty if not used) =====
FAMILY_MEMBER=                       # Important family member referenced in soul

# ===== Tools & integrations (all optional) =====
TELEGRAM_CHAT_ID=                    # Your personal chat ID for token-tracker.sh alerts
TELEGRAM_BOT_TOKEN=                  # via @BotFather (or store in macOS Keychain)
DISCORD_GUILD_ID=
DISCORD_APP_ID=
DATABASE=Postgres                    # Default DB for your projects

# ===== Anthropic / Claude Code =====
ANTHROPIC_API_KEY=                   # Only if you use the SDK; NOT needed for Claude Code CLI

# Note: Anything left empty stays as {{XXX}} in the generated files
# (signaling to you that you can fill it in later).
